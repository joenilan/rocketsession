{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rocket Session Stats",
  "version": "0.1.0",
  "identifier": "com.rocketsession.stats",
  "build": {
    "beforeDevCommand": "bun run dev:ui",
    "devUrl": "http://localhost:49411",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rocket Session Stats",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
