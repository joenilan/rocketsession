{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rocket Session Stats",
  "version": "1.0.0",
  "identifier": "com.rocketsession.stats",
  "build": {
    "beforeDevCommand": "bun run dev:ui",
    "devUrl": "http://localhost:49411",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rocket Session Stats",
        "width": 860,
        "height": 620,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": {
      "../dist": "dist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
